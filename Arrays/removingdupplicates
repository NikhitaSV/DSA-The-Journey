//method 3

#include <iostream>
#include <vector>
using namespace std;

int main() {
    vector<int> v;
    int x;

    cout << "Enter sorted elements (Ctrl+D to stop): ";

    while (cin >> x) {
        v.push_back(x);
    }

    if (v.size() == 0) {
        cout << "Vector is empty.";
        return 0;
    }

    // Two-pointer technique
    int j = 0;  // Points to last unique element

    for (int i = 1; i < v.size(); i++) {
        if (v[i] != v[j]) {
            j++;
            v[j] = v[i];
        }
    }

    cout << "After removing duplicates: ";

    // Only print unique part (0 to j)
    for (int i = 0; i <= j; i++) {
        cout << v[i] << " ";
    }

    return 0;
}
