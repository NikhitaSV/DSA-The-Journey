//rotating by 1

include<iostream>
using namespace std;

int main()
{
    int a[5]={1,2,3,4,5};
    int i,n=5;
    
    int temp=a[0];
    for(i=0;i<5;i++)
    {
       a[i]=a[i+1]; 
    }
    a[n-1]=temp;
    for(i=0;i<5;i++)
    {
        cout<<a[i]<<" ";
    }
    return 0;
}

//rotating by d places

#include<bits/stdc++.h>
using namespace std;
int main()
{
    int a[100];
    int i,n,d;
    
    cout<<"Enter n: ";
    cin>>n;
    
    cout<<"Enter array elements: ";
    for(i=0;i<n;i++)
    {
        cin>>a[i];
    }
    
    cout<<"Enter rotation number: ";
    cin>>d;
    
    d=d%n;
    
    int temp[100];
    
    for(i=0;i<d;i++)  
    {
     temp[i]=a[i];
    } 

    for(i=0;i<n-d;i++)
    {
        a[i]=a[i+d];
    }
    //also for(i=d;i<n;i++){a[i-d]=a[i]
    int j=0;
    for(i=n-d;i<n;i++)
    {
     a[i]=temp[j];
     j++;
    }
    
    cout<<"Rotated array is: ";
    for(i=0;i<n;i++)
    {
        cout<<a[i]<<" ";
    }
    
    return 0;
}
