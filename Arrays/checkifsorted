//method 1

#include <iostream>
#include <vector>
using namespace std;

bool isSorted(vector<int>& v) {
    for (int i = 1; i < v.size(); i++) {
        if (v[i] < v[i - 1])
            return false;   // Early exit
    }
    return true;
}

int main() {
    vector<int> v = {1, 2, 3, 4, 5};

    if (isSorted(v))
        cout << "Sorted";
    else
        cout << "Not Sorted";
}

