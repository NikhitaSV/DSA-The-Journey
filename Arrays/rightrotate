#include<bits/stdc++.h>
using namespace std;
int main()
{
    int a[100];
    int i,n,d;
    
    cout<<"Enter n: ";
    cin>>n;
    
    cout<<"Enter array elements: ";
    for(i=0;i<n;i++)
    {
        cin>>a[i];
    }
    
    cout<<"Enter rotation number: ";
    cin>>d;
    
    d=d%n;
    
    int temp[100];

    
    for(i=0;i<d;i++)
    {
        temp[i]=a[n-d+i];
    }
    for(i=n-1;i>=d;i--)
    {
        a[i]=a[i-d];
    }
    for(i=0;i<d;i++)
    {
        a[i]=temp[i];
    }
    cout<<"Rotated array is: ";
    for(i=0;i<n;i++)
    {
        cout<<a[i]<<" ";
    }
    
    return 0;
}

////right rotation optimal way

#include<bits/stdc++.h>
using namespace std;

void reverse(int a[], int start, int end)
{
    while(start < end)
    {
        int temp = a[start];
        a[start] = a[end];
        a[end] = temp;

        start++;
        end--;
    }
}

int main()
{
    int a[100];
    int i,n,d;

    cout<<"Enter n: ";
    cin>>n;

    cout<<"Enter array elements: ";
    for(i=0;i<n;i++)
    {
        cin>>a[i];
    }

    cout<<"Enter rotation number: ";
    cin>>d;

    d = d % n;

    reverse(a,n-d,n-1);
    reverse(a,0,n-d-1);
    reverse(a,0,n-1);

    cout<<"Rotated array is: ";
    for(i=0;i<n;i++)
    {
        cout<<a[i]<<" ";
    }

    return 0;
}
