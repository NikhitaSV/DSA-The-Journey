#include<iostream>
using namespace std;

int main()
{
    int a[100];
    int i,n;

    cout<<"Enter n: ";
    cin>>n;

    cout<<"Enter array elements: ";
    for(i=0;i<n;i++)
    {
        cin>>a[i];
    }
    int count=0,max=0;
    for(i=0;i<n;i++)
    {
        if(a[i]==1)
        {
            count++;
           if(count > max)
            {
                max = count;
            }
        }
        
        else
        {
            count=0;
        }
    }
    cout<<"Max ones is: "<<max;
    return 0;
}
